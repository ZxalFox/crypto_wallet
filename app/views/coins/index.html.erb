<%# app/views/coins/index.html.erb %>
<div class="container mt-5">
  <% if notice %>
    <div class="alert alert-success">
      <%= notice %>
    </div>
  <% end %>

  <h1 class="mb-4">Moedas</h1>

  <table class="table table-striped table-bordered">
    <thead class="thead-dark">
      <tr>
        <th>Descrição</th>
        <th>Sigla</th>
        <th>URL da Imagem</th>
        <th colspan="3">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @coins.each do |coin| %>
        <tr>
          <td><%= coin.description %></td>
          <td><%= coin.acronym %></td>
          <td><%= image_tag asset_path(coin.url_image), size: "30x30", class: "img-thumbnail" %></td>
          <td><%= link_to 'Mostrar', coin, class: "btn btn-primary btn-sm" %></td>
          <td><%= link_to 'Editar', edit_coin_path(coin), class: "btn btn-warning btn-sm" %></td>
          <td><%= link_to 'Deletar', coin, method: :delete, data: { confirm: 'Tem certeza?' }, class: "btn btn-danger btn-sm" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-4">
    <%= link_to "Cadastrar nova moeda", new_coin_path, class: "btn btn-success" %>
  </div>
</div>
