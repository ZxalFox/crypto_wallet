<p style="color: green"><%= notice %></p>

<h1>Moedas</h1>

<table>
<thead>
  <tr>
    <th>Descrição</th>
    <th>Sigla</th>
    <th>URL da imagem</th>
    <th colspan="3">Ações</th>
</tr>
</head>

<tbody>
<% @coins.each do |coin| %>
  <tr>
    <td><%= coin.description %></td>
    <td><%= coin.acronym %></td>
    <td><%= image_tag coin.url_image, size: "25x25" %></td>
    <td><%= link_to 'Mostrar', coin %></td>
    <td><%= link_to 'Editar', edit_coin_path(coin) %></td>
    <td><%= link_to 'Deletar', coin, method: :delete, data: { confirm: 'Tem certeza?' } %></td>
  </tr>
<% end %>
</tbody>
</table>

</div>

