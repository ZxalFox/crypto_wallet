<%# app/views/coins/_form.html.erb %>
<%= form_with(model: coin, local: true, class: "needs-validation") do |form| %>
  <% if coin.errors.any? %>
    <div class="alert alert-danger">
      <h4 class="alert-heading"><%= pluralize(coin.errors.count, "error") %> proibiu esta moeda de ser salva:</h4>
      <ul>
        <% coin.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :description, class: "form-label" %>
    <%= form.text_field :description, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :acronym, class: "form-label" %>
    <%= form.text_field :acronym, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :url_image, class: "form-label" %>
    <%= form.text_field :url_image, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.submit 'Salvar', class: "btn btn-primary" %>
  </div>
<% end %>
